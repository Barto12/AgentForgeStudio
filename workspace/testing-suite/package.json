{
  "name": "testing-suite",
  "version": "1.0.0",
  "description": "Suite completa de testing con Jest, Cypress y herramientas de calidad",
  "main": "src/index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "start": "node src/index.js",
    "dev": "nodemon src/index.js"
  },
  "keywords": ["testing", "jest", "cypress", "quality-assurance"],
  "author": "Test Agent",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "cypress": "^12.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^2.0.0",
    "supertest": "^6.0.0"
  },
  "dependencies": {
    "express": "^4.18.0"
  }
}